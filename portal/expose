#!/usr/bin/env bash
set -euo pipefail

# Resolve portal directory: use PORTAL_DIR env var if set (e.g. inside
# containers where the script and data dirs are mounted separately),
# otherwise assume data dirs are next to the script.
if [[ -z "${PORTAL_DIR:-}" ]]; then
    SCRIPT="$0"
    [[ -L "$SCRIPT" ]] && SCRIPT="$(readlink -f "$SCRIPT")"
    PORTAL_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
fi
DYNAMIC_DIR="$PORTAL_DIR/dynamic"
SERVICES_DIR="$PORTAL_DIR/services"
HOMEPAGE_DIR="$PORTAL_DIR/homepage"

usage() {
    cat <<EOF
Usage: expose <command> [args...]

Commands:
  add <name> <port> [description]   Register a service with the portal
  rm <name>                         Unregister a service
  ls                                List exposed services

Examples:
  expose add myapp 5001 "Flask dashboard for repo X"
  expose add notebook 8888
  expose rm myapp
  expose ls
EOF
    exit 1
}

# Regenerate Homepage services.yaml from all service metadata files
regen_homepage() {
    local yaml="$HOMEPAGE_DIR/services.yaml"
    {
        echo "---"
        echo "# Regenerated by the expose script. Do not edit manually."

        local files=("$SERVICES_DIR"/*)
        if [[ -e "${files[0]}" ]]; then
            echo "- Services:"
            for f in "$SERVICES_DIR"/*; do
                local name
                name="$(basename "$f")"
                local port desc
                port="$(awk '{print $1}' "$f")"
                desc="$(cut -d' ' -f2- "$f")"
                cat <<ENTRY
    - $name:
        href: /$name/
        description: "$desc"
        icon: mdi-application-outline
ENTRY
            done
        else
            echo "- Services: []"
        fi
    } > "$yaml"
}

cmd_add() {
    local name="${1:?Usage: expose add <name> <port> [description]}"
    local port="${2:?Usage: expose add <name> <port> [description]}"
    local desc="${3:-$name on port $port}"

    # Validate name (alphanumeric + hyphens)
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        echo "Error: name must be lowercase alphanumeric with hyphens" >&2
        exit 1
    fi

    # Refuse reserved names
    case "$name" in
        api|dashboard|traefik|homepage)
            echo "Error: '$name' is reserved" >&2
            exit 1
            ;;
    esac

    # Write Traefik dynamic route config
    cat > "$DYNAMIC_DIR/${name}.yml" <<EOF
http:
  routers:
    ${name}:
      rule: "PathPrefix(\`/${name}\`)"
      entryPoints:
        - web
      service: ${name}
      middlewares:
        - ${name}-strip

  middlewares:
    ${name}-strip:
      stripPrefix:
        prefixes:
          - "/${name}"

  services:
    ${name}:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:${port}"
EOF

    # Write service metadata
    mkdir -p "$SERVICES_DIR"
    echo "${port} ${desc}" > "$SERVICES_DIR/${name}"

    # Update Homepage
    regen_homepage

    echo "Exposed: /${name}/ -> localhost:${port}"
}

cmd_rm() {
    local name="${1:?Usage: expose rm <name>}"

    rm -f "$DYNAMIC_DIR/${name}.yml"
    rm -f "$SERVICES_DIR/${name}"
    regen_homepage

    echo "Removed: ${name}"
}

cmd_ls() {
    if [[ ! -d "$SERVICES_DIR" ]] || [[ -z "$(ls -A "$SERVICES_DIR" 2>/dev/null)" ]]; then
        echo "No services exposed."
        return
    fi

    printf "%-20s %-8s %s\n" "NAME" "PORT" "DESCRIPTION"
    printf "%-20s %-8s %s\n" "----" "----" "-----------"
    for f in "$SERVICES_DIR"/*; do
        local name port desc
        name="$(basename "$f")"
        port="$(awk '{print $1}' "$f")"
        desc="$(cut -d' ' -f2- "$f")"
        printf "%-20s %-8s %s\n" "$name" "$port" "$desc"
    done
}

# --- Main ---
if [[ $# -lt 1 ]]; then
    usage
fi

cmd="$1"
shift

case "$cmd" in
    add)  cmd_add "$@" ;;
    rm)   cmd_rm "$@" ;;
    ls)   cmd_ls ;;
    *)    usage ;;
esac
